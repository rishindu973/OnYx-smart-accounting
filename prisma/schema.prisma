// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // url      = "postgresql://postgres:password123@localhost:5432/onyx-db?schema=public"
}
//identity strategy: "uuid" is used for generating unique identifiers
//1-1 relationship between User and Company
model User{
  id                String     @id @default(cuid())
  name              String?
  email             String     @unique
  password          String
  companyId         String     @unique
  company           Company    @relation(fields: [companyId], references: [id])
}
model Company{
  id                String     @id @default(cuid())
  name              String
  dailyLimitBase    Decimal    @default(0) @map("daily_limit") @db.Decimal(15,2)
  fiscalYearStart   DateTime   @map("fiscal_year_start")
  
  //relationships
  user              User?
  accounts          ChartOfAccounts[]
  documents         Document[]
  dailyLimits       DailyLimit[]
  vendorMappings    VendorMapping[]
  journalEntries    JournalEntry[]

}

model ChartOfAccounts{
  id                String     @id @default(cuid())
  companyId         String
  company           Company    @relation(fields: [companyId], references: [id])
  name              String     @map("account_name")
  type              AccountType     @map("account_type")
  code              String     @map("account_code")
  currentBalance    Decimal    @default(0) @map("current_balance") @db.Decimal(15,2) 
  isDraft           Boolean    @default(false) @map("is_draft")
  tags              Json?

  ledgerLines      LedgerLine[]

  //self refferential relationship for sub accounts(utility -> electricity)
  parentAccountId  String?              @map("parent_account_id")
  parentAccount    ChartOfAccounts?     @relation("subAccounts", fields: [parentAccountId], references: [id])
  childAccounts    ChartOfAccounts[]    @relation("subAccounts")
  
  @@unique([companyId, code])
}

enum AccountType{
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

//document and ai drafted flags
model Document{
  id                String     @id @default(cuid())
  companyId         String
  company           Company    @relation(fields: [companyId], references: [id])
  fileUrl           String?    @map("file_url")
  type              DocType
  status            DocStatus  @default(PENDING)

  //ai extracted data-link to the ocr/model
  extraction        ExtractedInformation?
  journalEntry      JournalEntry[]

}
enum DocType{ 
  Cheque
  Invoice
  Bill
  Other
}
enum DocStatus{ 
  PENDING
  PROCESSED
  FAILED
}

model ExtractedInformation{
  id                    String          @id @default(cuid())
  documentId            String          @unique
  document              Document        @relation(fields: [documentId], references: [id])
  extractedData         Json            @map("extracted_data")
  totalAmount           Decimal         @default(0.00) @map("total_amount") @db.Decimal(15, 2)
  confidenceScores      Json            @map("confidence_score")
  amountValidationPass  Boolean         @default(false) @map("amount_validation")
  isManual              Boolean         @default(false) @map("is_manual")
}

// ledger and governance models(for audit trail and bookkeeping)
model JournalEntry{
  id                   String          @id @default(cuid())
  companyId            String
  company              Company         @relation(fields: [companyId], references: [id])
  documentId           String?
  document             Document?       @relation(fields: [documentId], references: [id])
  

  //self refferring keys for the reversals entries
  reversalOfId         String?         @unique @map("reversal_of_id")
  reversalOf           JournalEntry?   @relation("ReversalEntries", fields: [reversalOfId],references: [id])
  revertedBy           JournalEntry?   @relation("ReversalEntries")

  entryDate            DateTime         @map("entry_date")
  description          String?
  sourceType           SourceType
  entryType            EntryType        @default(STANDARD) @map("entry_type")
  createdAt            DateTime         @default(now()) @map("created_at") 

  ledgerLines          LedgerLine[]
}

enum SourceType {
      AI_SCAN
      USER_INPUT  
}
enum EntryType {
      STANDARD
      REVERSAL  
}
// ledger lines for each journal entry
model LedgerLine{
  id               String           @id @default(cuid())
  journalEntryId   String
  journalEntry     JournalEntry     @relation(fields: [journalEntryId], references: [id])
  accountId        String
  account          ChartOfAccounts  @relation(fields: [accountId], references: [id])
  debit            Decimal          @default(0) @db.Decimal(15,2) 
  credit           Decimal          @default(0) @db.Decimal(15,2)
  lineDescription  String?          @map("line_description")
}
//daily limit tracking for companies
model DailyLimit{
  id               String           @id @default(cuid())
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id])
  date             DateTime
  maxAmount        Decimal          @default(0) @map("max_amount") @db.Decimal(15,2)
  currentSpend     Decimal          @default(0) @map("current_spend") @db.Decimal(15,2)
  
  @@unique([companyId, date])
}

//vendor mapping to match naming conventions(suggestion memory)
model VendorMapping{
  id               String           @id @default(cuid())
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id])
  vendorName       String           @map("vendor_name")
  // mappedName       String      @map("mapped_name")
  defaultDebitAccountId  String     @map("default_debit_account_id")
  defaultCreditAccountId  String    @map("default_credit_account_id")

  @@unique([companyId, vendorName])
}