//  NEW: No-delete audit trail for DailyLimit changes
model DailyLimitAudit {
  id            String    @id @default(cuid())
  dailyLimitId  String    @map("daily_limit_id")
  dailyLimit    DailyLimit @relation(fields: [dailyLimitId], references: [id], onDelete: Restrict)

  changedBy     String?   @map("changed_by") // you can store userId/email/name
  oldMaxAmount  Decimal?  @map("old_max_amount") @db.Decimal(15,2)
  newMaxAmount  Decimal   @map("new_max_amount") @db.Decimal(15,2)
  reason        String?   @map("reason")
  changedAt     DateTime  @default(now()) @map("changed_at")

  @@index([dailyLimitId])
  @@index([changedAt])
}

model DailyLimitAudit {
  id           String     @id @default(cuid())
  dailyLimitId String     @map("daily_limit_id")
  dailyLimit   DailyLimit @relation(fields: [dailyLimitId], references: [id])
  oldMaxAmount Decimal?   @map("old_max_amount") @db.Decimal(15, 2)
  newMaxAmount Decimal    @map("new_max_amount") @db.Decimal(15, 2)
  reason       String?
  changedBy    String?    @map("changed_by")
  changedAt    DateTime   @default(now()) @map("changed_at")
}


//vendor mapping to match naming conventions(suggestion memory)
model VendorMapping{
  id               String           @id @default(cuid())
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id])
  vendorName       String           @map("vendor_name")
  // mappedName       String      @map("mapped_name")
  defaultDebitAccountId  String     @map("default_debit_account_id")
  defaultDebitAccount    ChartOfAccounts  @relation("debitAccount", fields: [defaultDebitAccountId], references: [id])
  defaultCreditAccountId  String    @map("default_credit_account_id")
  defaultCreditAccount   ChartOfAccounts  @relation("creditAccount", fields: [defaultCreditAccountId], references: [id])

  @@unique([companyId, vendorName])
  @@index([defaultDebitAccountId])
  @@index([defaultCreditAccountId])
}
